{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "baseUrl": ".",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@troppaye/shared": ["../../packages/shared/src/index.ts"],
      "@troppaye/shared/*": ["../../packages/shared/src/*"],
      "@troppaye/rules-engine": ["../../packages/rules-engine/src/index.ts"],
      "@troppaye/rules-engine/*": ["../../packages/rules-engine/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
