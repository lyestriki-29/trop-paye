# ============================================================
# TropPayé — Modèle de variables d'environnement (COMMITTÉ, sans secret)
# Copie ce fichier en .env.local et remplis les valeurs.
# ============================================================

# ---------- Supabase (projet région PARIS / eu-west-3) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=
SUPABASE_PROJECT_REF=

# ---------- Stockage des pièces ----------
SUPABASE_STORAGE_BUCKET=pieces
PIECES_ENCRYPTION_KEY=

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# ---------- Signature électronique MAISON (eIDAS simple) ----------
SIGNATURE_SECRET=

# ---------- Cron interne (Actions dues J0/J21/J35/J50) ----------
CRON_SECRET=

# ---------- Emails transactionnels ----------
EMAIL_PROVIDER=outbox
EMAIL_FROM=TropPayé <no-reply@troppaye.fr>
RESEND_API_KEY=
BREVO_API_KEY=

# ---------- APIs publiques (gratuites, sans clé) ----------
GEO_API_BASE=https://data.geopf.fr/geocodage
ADEME_DPE_API_BASE=https://data.ademe.fr/data-fair/api/v1/datasets
ADEME_DPE_DATASET=dpe03existant
INSEE_IRL_SERIES=001515333

# ---------- Observabilité (optionnel) ----------
SENTRY_DSN=
