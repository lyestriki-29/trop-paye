# ==================================================================
# TropPayé — Variables d'environnement PROD / Coolify (COMMITTÉ, sans secret)
# À reporter dans Coolify > Environment Variables. Ne JAMAIS mettre de valeur ici.
# Légende : [REQUIS] obligatoire · [OPT] optionnel · [BUILD] aussi en build arg
# (inliné côté client, cf. Dockerfile) · [SECRET] cocher « secret » dans Coolify.
# ==================================================================

# ---------- Supabase CLOUD (région Paris, PAS le local :55321) ----------
# [REQUIS][BUILD] URL + clé anon du projet PROD.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# [REQUIS][SECRET] clé service_role du projet PROD (bypass RLS, serveur seul).
SUPABASE_SERVICE_ROLE_KEY=

# ---------- App ----------
# [REQUIS][BUILD] URL publique de prod (ex. https://app.troppaye.fr).
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=
# NODE_ENV est fixé à "production" par le Dockerfile : ne pas le surcharger.

# ---------- Secrets à GÉNÉRER (openssl rand -hex 32) ----------
# [REQUIS][SECRET] HMAC de la preuve de signature.
SIGNATURE_SECRET=
# [REQUIS][SECRET] protège la route cron interne (J0/J21/J35/J50), en Bearer.
CRON_SECRET=
# [REQUIS][SECRET] chiffrement AES-256 des pièces. 64 hex = openssl rand -hex 32.
# ⚠️ STABLE À VIE : la changer rend toutes les pièces déjà chiffrées ILLISIBLES.
PIECES_ENCRYPTION_KEY=

# ---------- Stockage ----------
# [OPT] défaut "pieces".
SUPABASE_STORAGE_BUCKET=pieces

# ---------- Emails transactionnels ----------
# [OPT] outbox (défaut, file silencieuse) | brevo | resend.
EMAIL_PROVIDER=outbox
EMAIL_FROM=TropPayé <no-reply@troppaye.fr>
# [SECRET, requis si EMAIL_PROVIDER=brevo / resend]
BREVO_API_KEY=
RESEND_API_KEY=
# ⚠️ Magic links : Supabase Auth a son PROPRE SMTP (2 mails/h sans SMTP custom).
#    Brancher le SMTP Brevo dans Supabase cloud (Auth > SMTP) AVANT ouverture publique.

# ---------- Pilote / flags ----------
# [OPT] false = écran mandat en liste d'attente ; true = signature de mandats ouverte.
MANDATE_ENABLED=false

# ---------- APIs publiques (défauts OK, sans clé) ----------
GEO_API_BASE=https://data.geopf.fr/geocodage
ADEME_DPE_API_BASE=https://data.ademe.fr/data-fair/api/v1/datasets
ADEME_DPE_DATASET=dpe03existant
INSEE_IRL_SERIES=001515333

# ---------- Génération de contenu blog/guides (OPT) ----------
ANTHROPIC_API_KEY=
CONTENT_MODEL=claude-opus-4-8

# ---------- Espace client — Contact (OPT) ----------
# [OPT][BUILD] Numéro WhatsApp international sans +, ex. 33612345678. Vide = bouton masqué.
NEXT_PUBLIC_WHATSAPP=
# [OPT][BUILD] URL Cal.com / Calendly pour prendre RDV. Vide = bouton masqué.
NEXT_PUBLIC_CAL_URL=

# ---------- Observabilité (OPT) ----------
SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# ==================================================================
# PAS dans Coolify (pas du runtime app) — pour TOI, afin de pousser la
# migration encadrement (0006) + le seed sur le Supabase CLOUD via le CLI :
#   SUPABASE_PROJECT_REF=     ref du projet cloud
#   DATABASE_URL=             Postgres (pooler) du cloud
#   DIRECT_URL=               Postgres direct (non-pooler), pour les migrations
# Procédure : supabase link --project-ref <ref> && supabase db push
#   puis seed pointé sur le cloud (NEXT_PUBLIC_SUPABASE_URL/SERVICE_ROLE_KEY du
#   cloud) : pnpm --filter @troppaye/web db:seed-encadrement
# ==================================================================
